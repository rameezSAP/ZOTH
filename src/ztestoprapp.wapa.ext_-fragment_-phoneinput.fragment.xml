<core:FragmentDefinition                                                                                                                                                                                                                                       
  xmlns="sap.m"                                                                                                                                                                                                                                                
  xmlns:core="sap.ui.core">                                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                               
  <!-- Force numeric keyboard on mobile -->                                                                                                                                                                                                                    
  <Input                                                                                                                                                                                                                                                       
    id="valueCharInput"                                                                                                                                                                                                                                        
    value="{value_char}"                                                                                                                                                                                                                                       
    type="Tel"                                                                                                                                                                                                                                                 
    showSuggestion="false"                                                                                                                                                                                                                                     
    maxLength="16"                                                                                                                                                                                                                                             
    placeholder="Enter numeric value" />                                                                                                                                                                                                                       
                                                                                                                                                                                                                                                               
</core:FragmentDefinition>                                                                                                                                                                                                                                     
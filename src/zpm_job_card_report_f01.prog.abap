    CLEAR LV_TASK_LIST.

    IF ES_HEADER-TASK_LIST_GROUP IS NOT INITIAL.
      LV_INT = STRLEN( ES_HEADER-TASK_LIST_GROUP ).
      LV_INT_COUNT_REMAINING = 8 - LV_INT.
      LV_TASK_LIST = ES_HEADER-TASK_LIST_GROUP.
      DO LV_INT_COUNT_REMAINING TIMES.
        CONCATENATE LV_TASK_LIST '&' INTO LV_TASK_LIST.
*        LV_TASK_LIST = LV_TASK_LIST && ''.
      ENDDO.
    ENDIF.


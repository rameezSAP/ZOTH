        IT_TLINE       = IT_TLINE
      IMPORTING
        EV_TEXT_STRING = GS_MAIN-TDLINE.



**
**
**
**
**
**    GS_MAIN-TDLINE = REDUCE STRING( INIT LV_WHERE_CLAUSE TYPE STRING
**                                 FOR LS_WERKS  IN LINES
**                               NEXT LV_WHERE_CLAUSE = LV_WHERE_CLAUSE && LS_WERKS-TDLINE  ).


    SHIFT GS_MAIN-EQUIPMENT LEFT DELETING LEADING '0'.
    SHIFT GS_MAIN-TASK_LIST_GROUP LEFT DELETING LEADING '0'.
    APPEND GS_MAIN TO GT_MAIN.
    FREE:GS_MAIN,ET_OLIST,ET_OPERATIONS,ES_HEADER,LS_ROOT,LS_TJ02T,LS_JCDS,LS_T024I,LS_OPT,HEADER,OLD_LINE_COUNTER,LINES,NAME."LS_OLIST.




  ENDLOOP.


ENDFORM.


class ZCL_IBAPI_ALM_ORD_MODIFY definition
  public
  final
  create public .

public section.

  interfaces IF_BADI_INTERFACE .
  interfaces IF_EX_IBAPI_ALM_ORD_MODIFY .
protected section.
private section.

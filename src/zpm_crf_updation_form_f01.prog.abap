*& <--  p2        text
*&---------------------------------------------------------------------*
FORM GET_DATA .

*break-point.
  DATA:ZRSNUM TYPE RESB-AUFNR.
  GET PARAMETER ID 'ZRSNUM' FIELD ZRSNUM.
  BREAK AC_ADNAN.

  SELECT * FROM ZPM_AS_BUILD_CDS
    INTO TABLE @DATA(LT_RESB)
    WHERE AUFNR = @ZRSNUM.

  IF LT_RESB IS NOT INITIAL.

*    SELECT * FROM ZPM_AS_BUILD_MSEG_CDS
*       INTO TABLE @DATA(LT_MSEG)
*      FOR ALL ENTRIES IN @LT_RESB
*      WHERE
*      RSNUM = @LT_RESB-RSNUM
*      AND MATNR = @LT_RESB-MATNR
*      AND AUFNR = @LT_RESB-AUFNR.
    SELECT * FROM ZPM_AS_BUILD_MSEG_CDS
       INTO TABLE @DATA(LT_MSEG)
      FOR ALL ENTRIES IN @LT_RESB
      WHERE
       ( RSNUM = @LT_RESB-RSNUM OR  AUFNR = @LT_RESB-AUFNR )
      AND MATNR = @LT_RESB-MATNR.
*      AND AUFNR = @LT_RESB-AUFNR..


    SELECT * FROM ZPM_AS_BUILD_PM_BUILT_CDS
      INTO TABLE @DATA(LT_BUILD)
     FOR ALL ENTRIES IN @LT_RESB
      WHERE RSNUM = @LT_RESB-RSNUM
     AND MATNR = @LT_RESB-MATNR
     AND AUFNR = @LT_RESB-AUFNR.
  ENDIF.

  SORT LT_RESB BY MATNR ASCENDING.
*BOC by Adnan Khan from Return Qty
  IF NOT LT_RESB IS INITIAL.
    SELECT * FROM ZPM_AS_BUILD_MSEG_RET_CDS
      INTO TABLE @DATA(LT_MSEG_262)
      FOR ALL ENTRIES IN @LT_RESB
      WHERE ( RSNUM = @LT_RESB-RSNUM OR  AUFNR = @LT_RESB-AUFNR ).
  ENDIF.
  SORT LT_MSEG BY MATNR ASCENDING.
*EOC by Adnan Khan from Return Qty
  LOOP AT LT_RESB INTO DATA(LS_RESB).


    MOVE-CORRESPONDING LS_RESB TO GS_MAIN.

*BOC by Adnan Khan from PM:AS build from MSGES
    GS_MAIN-CHARG = VALUE #( LT_MSEG[ RSNUM = LS_RESB-RSNUM MATNR = LS_RESB-MATNR AUFNR = LS_RESB-AUFNR ]-CHARG OPTIONAL ).
    DATA(LV_MSEG) = REDUCE DMSHB( INIT VAL TYPE FAGL_CURRVAL_10 FOR WA_ISSUE IN  LT_MSEG
                  WHERE ( MATNR = LS_RESB-MATNR  AND ( RSNUM = LS_RESB-RSNUM OR AUFNR = LS_RESB-AUFNR ) )  NEXT VAL = VAL + WA_ISSUE-ISSUED_QTY  ).
*    DATA(LV_MSEG) = VALUE #( LT_MSEG[ RSNUM = LS_RESB-RSNUM MATNR = LS_RESB-MATNR AUFNR = LS_RESB-AUFNR ]-ISSUED_QTY OPTIONAL ).
    IF LV_MSEG IS NOT INITIAL.
      GS_MAIN-ISSUED_QTY = LV_MSEG.
      CLEAR LV_MSEG.
    ENDIF.
*EOC by Adnan Khan from PM:AS build from MSGES

*BOC by Adnan Khan from PM:AS build ZPM_BUILT Custom Table
    DATA(LS_PM_BUILT) = VALUE #( LT_BUILD[ RSNUM = LS_RESB-RSNUM MATNR = LS_RESB-MATNR AUFNR = LS_RESB-AUFNR ] OPTIONAL ).
    IF LS_PM_BUILT IS NOT INITIAL.
      GS_MAIN-ASBUILT_QTY = LS_PM_BUILT-ASBUILT_QTY.
      GS_MAIN-ASBUILT_DATE = LS_PM_BUILT-ASBUILT_DATE.
      GS_MAIN-CPUDT   = LS_PM_BUILT-CPUDT.
      GS_MAIN-CPUTM   = LS_PM_BUILT-CPUTM.
      GS_MAIN-UNAME   = LS_PM_BUILT-UNAME.

    ENDIF.
*EOC by Adnan Khan from PM:AS build Custom Table

    GS_MAIN-RETURN_QTY = REDUCE DMSHB( INIT VAL TYPE FAGL_CURRVAL_10 FOR WA IN  LT_MSEG_262
                  WHERE ( MATNR = LS_RESB-MATNR )  NEXT VAL = VAL + WA-RETURN_QTY  ).


    GS_MAIN-BALANCE_QTY = GS_MAIN-ISSUED_QTY - GS_MAIN-RETURN_QTY.

    DATA MATERIAL_GENERAL_DATA TYPE BAPIMATDOA.
    DATA RETURN                TYPE BAPIRETURN.
    DATA MATERIALPLANTDATA     TYPE BAPIMATDOC.
    DATA MATERIALVALUATIONDATA TYPE BAPIMATDOBEW.
    DATA MATERIAL TYPE  MATNR18.

    MATERIAL = LS_RESB-MATNR.
    CALL FUNCTION 'BAPI_MATERIAL_GET_DETAIL'
      EXPORTING
        MATERIAL              = MATERIAL
        PLANT                 = LS_RESB-WERKS
        VALUATIONAREA         = LS_RESB-WERKS
*       VALUATIONTYPE         = VALUATIONTYPE
*       MATERIAL_EVG          = MATERIAL_EVG
*       MATERIAL_LONG         = MATERIAL_LONG
      IMPORTING
        MATERIAL_GENERAL_DATA = MATERIAL_GENERAL_DATA
        RETURN                = RETURN
        MATERIALPLANTDATA     = MATERIALPLANTDATA
        MATERIALVALUATIONDATA = MATERIALVALUATIONDATA.

    IF MATERIALVALUATIONDATA-PRICE_UNIT IS NOT INITIAL.
      GS_MAIN-UNIT_COST = MATERIALVALUATIONDATA-MOVING_PR / MATERIALVALUATIONDATA-PRICE_UNIT.
      GS_MAIN-WAERS = MATERIALVALUATIONDATA-CURRENCY .
    ELSE.
      GS_MAIN-UNIT_COST = MATERIALVALUATIONDATA-MOVING_PR.
      GS_MAIN-WAERS = MATERIALVALUATIONDATA-CURRENCY .
    ENDIF.


    GS_MAIN-ASBUILT_COST = GS_MAIN-ASBUILT_QTY *  GS_MAIN-UNIT_COST.
    GS_MAIN-OUTSTANDING_QTY = GS_MAIN-BALANCE_QTY -  GS_MAIN-ASBUILT_QTY.
    GS_MAIN-OUTSTANDING_COST = GS_MAIN-OUTSTANDING_QTY *  GS_MAIN-UNIT_COST.

    IF GS_MAIN-ASBUILT_DATE IS  INITIAL.
      GS_MAIN-ASBUILT_DATE =  SY-DATUM.
    ENDIF.

    APPEND GS_MAIN TO GT_MAIN.
    CLEAR: GS_MAIN,MATERIAL_GENERAL_DATA,
                   RETURN,
                   MATERIALPLANTDATA,
                   MATERIALVALUATIONDATA,
                   MATERIAL.
  ENDLOOP.
  GT_MAIN_TMP = GT_MAIN.
  SET PARAMETER ID 'ZRSNUM' FIELD SPACE.
*
ENDFORM.


FORM SET_OUTPUT.

  CLEAR IT_FIELDCAT.
  CREATE DATA LR_DATA LIKE LINE OF GT_MAIN.

*Create Field Cathlog From Internal Table
  LR_TABDESCR ?= CL_ABAP_STRUCTDESCR=>DESCRIBE_BY_DATA_REF( LR_DATA ).

  LT_DFIES = CL_SALV_DATA_DESCR=>READ_STRUCTDESCR( LR_TABDESCR ).


  LOOP AT LT_DFIES INTO LS_DFIES.
    CLEAR LS_FIELDCAT.
    MOVE-CORRESPONDING LS_DFIES TO LS_FIELDCAT.
    LS_FIELDCAT-REPTEXT_DDIC   = LS_DFIES-FIELDTEXT.
    LS_FIELDCAT-SELTEXT_L = LS_DFIES-FIELDTEXT.
    LS_FIELDCAT-SELTEXT_M = LS_DFIES-FIELDTEXT.
    LS_FIELDCAT-SELTEXT_L = LS_DFIES-FIELDTEXT.
    LS_FIELDCAT-OUTPUTLEN = 12.
    IF LS_DFIES-FIELDNAME = 'UNIT_COST'.
      LS_FIELDCAT-REPTEXT_DDIC      = 'Unit Cost '.
      LS_FIELDCAT-SELTEXT_S    = 'Unit Cost '.
      LS_FIELDCAT-SELTEXT_L    = 'Unit Cost '.
      LS_FIELDCAT-SELTEXT_M    = 'Unit Cost '.
      LS_FIELDCAT-OUTPUTLEN = 10.
    ELSEIF LS_DFIES-FIELDNAME = 'PLANNED_QTY'.
      LS_FIELDCAT-REPTEXT_DDIC      = 'Planned qty'.
      LS_FIELDCAT-SELTEXT_S    = 'Planned qty'.
      LS_FIELDCAT-SELTEXT_L    = 'Planned qty'.
      LS_FIELDCAT-SELTEXT_M    = 'Planned qty'.
      LS_FIELDCAT-OUTPUTLEN = 12.
    ELSEIF LS_DFIES-FIELDNAME = 'RETURN_QTY'.
      LS_FIELDCAT-REPTEXT_DDIC      = 'Return  qty'.
      LS_FIELDCAT-SELTEXT_S    = 'Return  qty'.
      LS_FIELDCAT-SELTEXT_L    = 'Return  qty'.
      LS_FIELDCAT-SELTEXT_M    = 'Return  qty'.
      LS_FIELDCAT-OUTPUTLEN = 10.
    ELSEIF LS_DFIES-FIELDNAME = 'BALANCE_QTY'.
      LS_FIELDCAT-REPTEXT_DDIC      = 'Balance qty '.
      LS_FIELDCAT-SELTEXT_S    = 'Balance qty '.
      LS_FIELDCAT-SELTEXT_L    = 'Balance qty '.
      LS_FIELDCAT-SELTEXT_M    = 'Balance qty '.
      LS_FIELDCAT-OUTPUTLEN = 10.
    ELSEIF LS_DFIES-FIELDNAME = 'OUTSTANDING_QTY'.
      LS_FIELDCAT-REPTEXT_DDIC      = 'Outstanding QTY'.
      LS_FIELDCAT-SELTEXT_S    = 'Outstanding QTY'.
      LS_FIELDCAT-SELTEXT_L    = 'Outstanding QTY'.
      LS_FIELDCAT-SELTEXT_M    = 'Outstanding QTY'.
      LS_FIELDCAT-OUTPUTLEN = 14.
    ELSEIF LS_DFIES-FIELDNAME = 'OUTSTANDING_COST'.
      LS_FIELDCAT-REPTEXT_DDIC      = 'Outstanding Cost'.
      LS_FIELDCAT-SELTEXT_S    = 'Outstanding Cost'.
      LS_FIELDCAT-SELTEXT_L    = 'Outstanding Cost'.
      LS_FIELDCAT-SELTEXT_M    = 'Outstanding Cost'.
      LS_FIELDCAT-OUTPUTLEN = 14..
    ELSEIF LS_DFIES-FIELDNAME = 'ISSUED_QTY'.
      LS_FIELDCAT-REPTEXT_DDIC      = 'Issued qty'.
      LS_FIELDCAT-SELTEXT_S    = 'Issued qty'.
      LS_FIELDCAT-SELTEXT_L    = 'Issued qty'.
      LS_FIELDCAT-SELTEXT_M    = 'Issued qty'.
      LS_FIELDCAT-OUTPUTLEN = 14.
    ELSEIF LS_DFIES-FIELDNAME = 'ASBUILT_COST'.
      LS_FIELDCAT-REPTEXT_DDIC = 'As Build Cost '.
      LS_FIELDCAT-SELTEXT_S    = 'As Build Cost '.
      LS_FIELDCAT-SELTEXT_L    = 'As Build Cost '.
      LS_FIELDCAT-SELTEXT_M    = 'As Build Cost '.
      LS_FIELDCAT-OUTPUTLEN = 14.
    ELSEIF LS_DFIES-FIELDNAME = 'ASBUILT_DATE'.
*      LS_FIELDCAT-EDIT      = ABAP_TRUE.
      LS_FIELDCAT-REF_TABNAME      = 'ZPM_BUILT'.
      LS_FIELDCAT-REF_FIELDNAME      = 'ASBUILT_DATE'.
      LS_FIELDCAT-OUTPUTLEN = 10.
    ELSEIF LS_DFIES-FIELDNAME     = 'ASBUILT_QTY'.
      LS_FIELDCAT-EDIT            = ABAP_TRUE.
      LS_FIELDCAT-REF_TABNAME     = 'ZPM_BUILT'.
      LS_FIELDCAT-REF_FIELDNAME   = 'ASBUILT_QTY'.
      LS_FIELDCAT-DATATYPE   = 'QUAN'.
      LS_FIELDCAT-NO_ZERO =  SPACE..
    ELSEIF LS_DFIES-FIELDNAME     = 'WAERS'.
      LS_FIELDCAT-REPTEXT_DDIC = 'Currency'.
      LS_FIELDCAT-SELTEXT_S    = 'Currency'.
      LS_FIELDCAT-SELTEXT_L    = 'Currency'.
      LS_FIELDCAT-SELTEXT_M    = 'Currency'.
*      LS_FIELDCAT-EDIT            = ABAP_TRUE.
*      LS_FIELDCAT-REF_TABNAME     = 'BKPF'.
*      LS_FIELDCAT-REF_FIELDNAME   = 'WAERS'.
    ENDIF.

*    LS_FIELDCAT-REF_FIELDNAME   = 'WAERS'.
    IF LS_DFIES-FIELDNAME     <> 'CHARG'.
      LS_FIELDCAT-NO_ZERO = 'X'.
    ENDIF.

*    DATA LV_LENGTH TYPE I .
*    IF LS_DFIES-FIELDTEXT IS INITIAL.
*      LV_LENGTH = STRLEN( LS_FIELDCAT-REPTEXT_DDIC ).
*    ELSE.
*      LV_LENGTH = STRLEN( LS_DFIES-FIELDTEXT ).
*    ENDIF.

    APPEND LS_FIELDCAT TO IT_FIELDCAT.
    CLEAR: LS_FIELDCAT,LS_DFIES.
  ENDLOOP.


*Display ALV Report
  CONSTANTS LC_SAVE_ALL TYPE C VALUE 'A'.
*  LS_LAYO-EDIT = 'X'.
  CALL FUNCTION 'REUSE_ALV_GRID_DISPLAY'
    EXPORTING
      I_CALLBACK_PROGRAM       = SY-REPID
      I_CALLBACK_TOP_OF_PAGE   = 'TOP_OF_PAGE'
      I_CALLBACK_USER_COMMAND  = 'USER_COMMAND'   "see FORM
      IT_FIELDCAT              = IT_FIELDCAT[]
      I_SAVE                   = LC_SAVE_ALL
      IS_LAYOUT                = LS_LAYO
      I_CALLBACK_PF_STATUS_SET = 'PFSTAT'
*     I_SAVE                   = 'A'
*     IS_VARIANT               = GX_VARIANT
   "  IT_SORT_LVC              = IT_SORT
    TABLES
      T_OUTTAB                 = GT_MAIN "Global Table for output
    EXCEPTIONS
      PROGRAM_ERROR            = 1
      OTHERS                   = 2.
  IF SY-SUBRC <> 0.
* Implement suitable error handling here

  ENDIF.

ENDFORM.


  //   RouteId;
  @UI: {
  //selectionField: [{position: 20 }],
          lineItem: [{position: 20 }],
          identification: [{position: 20 }]
          }
  @Search.fuzzinessThreshold: 0.8
  @Search.defaultSearchElement: true
  @EndUserText.label: 'Route ID'
  RouteId;
  //   RouteId;
  @UI: {  selectionField: [{position: 10 }],
          lineItem: [{position: 9 },{type: #FOR_ACTION ,dataAction: 'CompleteRoute', label: 'Complete' }],
          identification: [{position: 9 },{type: #FOR_ACTION ,dataAction: 'CompleteRoute', label: 'Complete' }]
          }
  @Search.defaultSearchElement: true
  @Consumption.valueHelpDefinition: [{
    entity: {
        name: 'zi_pm_loc_txt_r',
        element: 'Location'
    }
  }]

  Location;

  @UI: {  selectionField: [{position: 11 }],
         lineItem: [{position: 11 }],
         identification: [{position: 11 }]
         }
  @Search.defaultSearchElement: true
  @Consumption.valueHelpDefinition: [{
    entity: {
        name: 'ZI_PM_PLANT_TXT_R',
        element: 'Plant'
    }, additionalBinding: [{localElement: 'Location' ,element: 'Location' }]
  }]

  Plant;

  @UI: {selectionField: [{position: 21 }],
       //   lineItem: [{position: 31,importance: #HIGH }],
           identification: [{position: 31 , label: 'Actual Hours' }]
          }

  //  @Search.defaultSearchElement: true
  @Consumption.valueHelpDefinition: [{
  entity: {
      name: 'ZI_PM_DATE_TXT_R',
      element: 'EvenDate'
  }
  }]
  ETimeEven;

  @UI: {
        lineItem: [{position: 32,importance: #HIGH
        }],
         identification: [{position: 32  }]}

  //  @Search.defaultSearchElement: true
  ETime;
  //  EDate;

  //   EDate;
  @UI.lineItem: [{position: 40 }]
  @UI.identification: [{position: 40 }]
  EDate;
  //  ETime;

  //   @UI: {
  //           identification: [{position: 50 }]
  //          }


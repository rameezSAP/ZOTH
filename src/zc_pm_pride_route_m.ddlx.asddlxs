  @UI.lineItem: [{position: 50 ,criticality: 'critical', importance: #HIGH}]
  @UI.identification: [{position: 60,criticality: 'critical'}]
  @UI.dataPoint: { qualifier: 'PendingCount', title: 'Pending Count', criticality: 'critical' }
  PendingCount;
  //   ETime;
  @UI.lineItem: [{position: 80 }]
  @UI.identification: [{position: 50
  }]
  Sechedule;
  @UI.lineItem: [{position: 90 }]
  @UI.textArrangement: #TEXT_ONLY
  Active;

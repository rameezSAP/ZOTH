@Metadata.layer: #CORE
@Search.searchable: true
@UI.headerInfo: {
    typeName: 'Route',
    typeNamePlural: 'Routes',
    title.value:  'RouteId'  , title.type: #STANDARD
}
annotate view ZC_PM_PRIDE_ROUTE_M with
{
  @UI.facet: [{
                  id: 'RouteHeaderInfo',
                  purpose: #HEADER,
                  type: #DATAPOINT_REFERENCE,
                  position: 10,
                  targetQualifier: 'PendingCount'
              },
              {
                  id: 'route',
                  position: 20,
                  label: 'Routes',
                  type: #IDENTIFICATION_REFERENCE
              },
              {
                  id: 'routeDetails',
                  position: 30,
                  label: 'Routes Details',
                  type: #LINEITEM_REFERENCE ,
                  targetElement: '_details'
              }
  //              ,
              // Body Facets (Object Page)

       // Facet for chart - charts can only be displayed in facets

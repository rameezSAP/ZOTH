    READ TABLE LT_IFLO INTO DATA(LS_IFLO) WITH KEY TPLNR = LS_VIQMEL-ZQMTXT+0(30) BINARY SEARCH.
    IF SY-SUBRC = 0.
      "   MOVE LS_IFLO-EQFNR TO GS_MAIN-TO_ZONE.

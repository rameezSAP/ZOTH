*For Cuntional Localtion custom
    SELECT * FROM IFLO
      INTO TABLE @DATA(LT_IFLO)
      FOR ALL ENTRIES IN @LT_VIQMEL
      WHERE TPLNR = @LT_VIQMEL-ZQMTXT+0(30)
      AND SPRAS = @SY-LANGU.

    SORT LT_IFLO BY TPLNR ASCENDING.
*For Cuntional Localtion Standed

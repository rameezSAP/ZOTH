    GS_MAIN-ENDMLFNDATE =    NOTIFHEADER_EXPORT-DESENDDATE.
    MOVE NOTIFHEADER_EXPORT-SORTFIELD TO GS_MAIN-FROM_ZONE.
    MOVE NOTIFHDTEXT-EQUIDESCR TO GS_MAIN-EQUIDESCR.

****    DATA:LT_SPLIT TYPE STRING.
****    SPLIT NOTIFHEADER_EXPORT-FUNCT_LOC AT '-' INTO LT_SPLIT.

    ""break-POINT.
    DATA: TEXT_TAB TYPE TABLE OF STRING.
    DATA: LV_TEXT TYPE STRING.
    CLEAR LV_ZONE.
    IF NOTIFHEADER_EXPORT-FUNCT_LOC IS NOT INITIAL.
      SPLIT NOTIFHEADER_EXPORT-FUNCT_LOC AT '-' INTO TABLE TEXT_TAB.
      DELETE  TEXT_TAB FROM 4 TO 99999.
      LV_ZONE  =  REDUCE #( INIT TEXT = `` FOR <LINE1> IN TEXT_TAB
                      NEXT  TEXT = TEXT && '-' &&  <LINE1>  ).
      SHIFT LV_ZONE LEFT DELETING LEADING  '-'.

      FUNCTLOCATION = LV_ZONE.

      CALL FUNCTION 'BAPI_FUNCLOC_GETDETAIL'
        EXPORTING
          FUNCTLOCATION             = FUNCTLOCATION
          REQUEST_INSTALLATION_DATA = 'X'
        IMPORTING
          DATA_GENERAL_EXP          = DATA_GENERAL_EXP
          DATA_SPECIFIC_EXP         = DATA_SPECIFIC_EXP
          RETURN                    = RETURN_ZONE
          DATA_INSTALLATION         = DATA_INSTALLATION
        TABLES
          EXTENSIONOUT              = EXTENSIONOUT_ZONE.
      GS_MAIN-FROM_ZONE = DATA_INSTALLATION-FUNCLOCSTRUCIDENTIFYINGOBJDESC.
    ENDIF.
    FREE TEXT_TAB.
    FREE LV_ZONE.
    IF LS_VIQMEL-ZQMTXT  IS NOT INITIAL.
      SPLIT LS_VIQMEL-ZQMTXT AT '-' INTO TABLE TEXT_TAB.
      DELETE  TEXT_TAB FROM 4 TO 99999.
      LV_ZONE  =  REDUCE #( INIT TEXT = `` FOR <LINE1> IN TEXT_TAB
                      NEXT  TEXT = TEXT && '-' &&  <LINE1>  ).
      SHIFT LV_ZONE LEFT DELETING LEADING  '-'.

      FUNCTLOCATION = LV_ZONE.
      CALL FUNCTION 'BAPI_FUNCLOC_GETDETAIL'
        EXPORTING
          FUNCTLOCATION             = FUNCTLOCATION
          REQUEST_INSTALLATION_DATA = 'X'
        IMPORTING
          DATA_GENERAL_EXP          = DATA_GENERAL_EXP
          DATA_SPECIFIC_EXP         = DATA_SPECIFIC_EXP
          RETURN                    = RETURN_ZONE
          DATA_INSTALLATION         = DATA_INSTALLATION
        TABLES
          EXTENSIONOUT              = EXTENSIONOUT_ZONE.
      GS_MAIN-TO_ZONE = DATA_INSTALLATION-FUNCLOCSTRUCIDENTIFYINGOBJDESC.
    ENDIF.

*    DATA(LV_LINES) = REDUCE I( INIT X = 0 FOR WA IN TEXT_TAB
*                  WHERE ( X = 3 )      NEXT X = X + 1 ).

*READ ASSET TAG (TECHNICAL IDN)
    GS_MAIN-ASSIT_TAG = VALUE #( LT_EQUZ[ EQUNR = NOTIFHEADER_EXPORT-EQUIPMENT ]-TIDNR OPTIONAL ).
    IF NOTIFHEADER_EXPORT-ENDMLFNDATE IS NOT INITIAL AND NOTIFHEADER_EXPORT-STRMLFNDATE IS NOT INITIAL.
      DATA:YEARS  TYPE  PEA_SCRYY,
           MONTHS TYPE  PEA_SCRMM,
           DAYS   TYPE  PEA_SCRDD.
      CALL FUNCTION 'HR_HK_DIFF_BT_2_DATES'
        EXPORTING
          DATE1         = NOTIFHEADER_EXPORT-ENDMLFNDATE
          DATE2         = NOTIFHEADER_EXPORT-STRMLFNDATE
          OUTPUT_FORMAT = '05'
        IMPORTING
          YEARS         = YEARS
          MONTHS        = MONTHS
          DAYS          = DAYS.


      GS_MAIN-DURATION =  MONTHS .
    ENDIF.
    DATA OBTYP       TYPE JSTO-OBTYP.
    DATA STSMA       TYPE JSTO-STSMA.
    DATA STONR       TYPE TJ30-STONR.
    DATA GT_STATUS      TYPE STANDARD TABLE OF JSTAT.

*For Status Text and code
    CALL FUNCTION 'STATUS_READ'
      EXPORTING
        CLIENT           = SY-MANDT
        OBJNR            = NOTIFHEADER_EXPORT-OBJECT_NO
        ONLY_ACTIVE      = 'X'
      IMPORTING
        OBTYP            = OBTYP
        STSMA            = STSMA
        STONR            = STONR
      TABLES
        STATUS           = GT_STATUS
      EXCEPTIONS
        OBJECT_NOT_FOUND = 1.

    SORT GT_STATUS BY STAT  DESCENDING.
    "break-POINT.
    DELETE GT_STATUS WHERE STAT+0(1) = 'E'.

    LOOP AT GT_STATUS INTO DATA(GS_STATUS) WHERE STAT = 'I0070' OR STAT = 'I0072' OR STAT = 'I0068' .
      READ TABLE LT_TJ02T INTO DATA(LS_TJ02T) WITH KEY ISTAT = GS_STATUS-STAT BINARY SEARCH.
      IF SY-SUBRC = 0.
        IF GS_MAIN-STAT IS  INITIAL .
          GS_MAIN-STAT = LS_TJ02T-TXT30.
        ENDIF.
      ENDIF.
    ENDLOOP.


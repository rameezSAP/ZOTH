    INTO TABLE @DATA(LT_JCDS)
          FOR ALL ENTRIES IN @LT_VIQMEL
          WHERE OBJNR = @LT_VIQMEL-OBJNR
          AND STAT LIKE 'E%'
          AND INACT <> 'X'.

    SORT LT_JCDS BY UDATE UTIME STAT DESCENDING.

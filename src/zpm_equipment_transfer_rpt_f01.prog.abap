*Read Movement Type Desc
    READ TABLE LT_T353I_T INTO DATA(LS_T353I_T) WITH KEY ILART = LS_VIQMEL-ILART BINARY SEARCH.
    IF SY-SUBRC = 0.
      MOVE LS_T353I_T-ILATX TO GS_MAIN-ILATX.
    ENDIF.

*Read Asset Condition
    READ TABLE LT_QPCT INTO DATA(LS_QPCT) WITH KEY KATALOGART = LS_VIQMEL-QMKAT
    CODEGRUPPE = LS_VIQMEL-QMGRP
    CODE = LS_VIQMEL-QMCOD
    BINARY SEARCH.
    IF SY-SUBRC = 0.
      MOVE LS_QPCT-KURZTEXT TO GS_MAIN-KURZTEXT.
    ENDIF.

*Movement Reason
    READ TABLE LT_T352R INTO DATA(LS_T352R) WITH KEY REVNR = LS_VIQMEL-REVNR
    IWERK = LS_VIQMEL-IWERK
    BINARY SEARCH.
    IF SY-SUBRC = 0.
      MOVE LS_T352R-REVTX TO GS_MAIN-MOVE_RES.
    ENDIF.

*Proposed By
    READ TABLE LT_USER_ADDR INTO DATA(LS_USER_ADDR) WITH KEY BNAME = LS_VIQMEL-QMNAM BINARY SEARCH.
    IF SY-SUBRC = 0.
      MOVE LS_USER_ADDR-NAME_TEXTC TO GS_MAIN-PROPOSED_BY.
    ENDIF.


*For Reviewed By:Approved By:Authorized By:
    FIELD-SYMBOLS:<FS> TYPE ANY.
    DATA:LV_FIELD TYPE STRING.
    ""break-POINT.

*Transferring Facility Representative:
    LOOP AT LT_JCDS INTO DATA(LS_JCDS)
      WHERE OBJNR = LS_VIQMEL-OBJNR.
      CLEAR LS_TJ02T.
      READ TABLE LT_TJ30T INTO DATA(LS_TJ30T) WITH KEY ESTAT = LS_JCDS-STAT." BINARY SEARCH.
      IF SY-SUBRC = 0.
        IF LS_TJ30T-TXT04 = 'RVWD'.
          LV_FIELD = 'GS_MAIN-REVIEWED_BY'.
        ELSEIF LS_TJ30T-TXT04 = 'APPR'.
          LV_FIELD = 'GS_MAIN-APPROVED_BY'.
        ELSEIF LS_TJ30T-TXT04 = 'CNRD'.
          LV_FIELD = 'GS_MAIN-TRANSFERRING_FACI'.
          GS_MAIN-TRANSFERRING_FACI_DATE = LS_JCDS-UDATE.
        ELSEIF LS_TJ30T-TXT04 = 'EXEC'.
          LV_FIELD = 'GS_MAIN-RECEIVING_FAC'.
          GS_MAIN-RECEIVING_FAC_DATE = LS_JCDS-UDATE.
        ELSEIF LS_TJ30T-TXT04 = 'ATHZ'.
          LV_FIELD = 'GS_MAIN-AUTHORIZED_BY'.

        ENDIF.

        ASSIGN (LV_FIELD) TO <FS>.
        IF <FS> IS ASSIGNED.
          READ TABLE LT_USER_ADDR INTO DATA(LS_USER_ADDR_FS) WITH KEY BNAME = LS_JCDS-USNAM BINARY SEARCH.
          IF SY-SUBRC = 0.
            MOVE LS_USER_ADDR_FS-NAME_TEXTC TO <FS>.
          ENDIF.
        ENDIF.
        CLEAR LV_FIELD.
      ENDIF.
    ENDLOOP.

*RReceiving Facility Representative:
    READ TABLE LT_AUFK INTO DATA(LS_AUFK) WITH KEY AUFNR = LS_VIQMEL-AUFNR.
    LOOP AT LT_JCDS_ORDER_REC_FAC INTO DATA(LS_JCDS_REC)
      WHERE OBJNR = LS_AUFK-OBJNR AND STAT = 'E0003'.
      CLEAR LS_TJ02T.
      LV_FIELD = 'GS_MAIN-RECEIVING_FAC'.
      GS_MAIN-RECEIVING_FAC_DATE = LS_JCDS-UDATE.

      ASSIGN (LV_FIELD) TO <FS>.
      IF <FS> IS ASSIGNED.
        READ TABLE LT_USER_ADDR INTO DATA(LS_USER_ADDR_FS_AUFK) WITH KEY BNAME = LS_JCDS_REC-USNAM BINARY SEARCH.
        IF SY-SUBRC = 0.
          MOVE LS_USER_ADDR_FS_AUFK-NAME_TEXTC TO <FS>.
        ENDIF.
      ENDIF.
      CLEAR LV_FIELD.
    ENDLOOP.

*For rority
    IF LS_VIQMEL-PRIOK = '1'.
      GS_MAIN-PRIOK = 'Urgent-(7 Days)'.
    ELSEIF LS_VIQMEL-PRIOK = '2'.
      GS_MAIN-PRIOK = 'Planned-(30 Days)'.
    ENDIF.

*For Pernr
*    "break-POINT.
    IF LS_VIQMEL-AUFNR IS NOT INITIAL.
      DATA: IAFVGD  TYPE STANDARD TABLE OF AFVGD,
            WCAUFVD LIKE  CAUFVD.
      CALL FUNCTION 'PM_ORDER_DATA_READ'
        EXPORTING
          ORDER_NUMBER    = LS_VIQMEL-AUFNR
*         CALL_FROM_NOTIF = 'X'
        IMPORTING
          WCAUFVD         = WCAUFVD
        TABLES
          IAFVGD          = IAFVGD
        EXCEPTIONS
          ORDER_NOT_FOUND = 1.
      DATA P_PERNR     TYPE PRELP-PERNR.
      CLEAR P_PERNR.
      GS_MAIN-IDAT2 = WCAUFVD-IDAT2.
      P_PERNR = VALUE #( IAFVGD[ VORNR = '0010' ]-PERNR OPTIONAL ).

*For Emp Name

*DATA P_DATE      TYPE D.
      DATA P_EMPLOYEE  TYPE PFRL0_EMPLOYEE.
      DATA P_TAB_ERROR TYPE P99SF_TAB_ERROR.
*DATA T0001       TYPE STANDARD TABLE OF P0001.
*DATA T0002       TYPE STANDARD TABLE OF P0002.
*DATA T0006       TYPE STANDARD TABLE OF P0006.
*DATA T0064       TYPE STANDARD TABLE OF P0064.
*DATA T0217       TYPE STANDARD TABLE OF P0217.

      IF P_PERNR IS NOT INITIAL.
        CALL FUNCTION 'HR_FR_GET_EMPLOYEE'
          EXPORTING
            P_PERNR     = P_PERNR
            P_DATE      = '99991231'
          IMPORTING
            P_EMPLOYEE  = P_EMPLOYEE
            P_TAB_ERROR = P_TAB_ERROR
*          TABLES
*           T0001       = T0001
*           T0002       = T0002
*           T0006       = T0006
*           T0064       = T0064
*           T0217       = T0217
          EXCEPTIONS
            ERROR       = 1.

        IF P_EMPLOYEE-SNAME IS NOT INITIAL.
          GS_MAIN-PERNR = P_EMPLOYEE-PERNR.
          GS_MAIN-NAME = P_EMPLOYEE-SNAME.
        ENDIF.
      ENDIF.
    ENDIF.

***    WHERE KATALOGART = @LT_VIQMEL-QMKAT
***     AND  CODEGRUPPE = @LT_VIQMEL-QMGRP
***     AND  CODE = @LT_VIQMEL-QMCOD
***      AND SPRACHE = @SY-LANGU.

    DELETE NOTLONGTXT INDEX 1.
    GS_MAIN-TDLINE = REDUCE STRING( INIT LV_WHERE_CLAUSE TYPE STRING
                               FOR LS_WERKS  IN NOTLONGTXT
                               NEXT LV_WHERE_CLAUSE = LV_WHERE_CLAUSE && LS_WERKS-TEXT_LINE ).


    APPEND GS_MAIN TO GT_MAIN.
    FREE:GS_MAIN.

  ENDLOOP.



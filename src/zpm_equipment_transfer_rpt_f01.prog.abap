      APPENDING CORRESPONDING FIELDS OF TABLE @LT_IFLO
      FOR ALL ENTRIES IN @LT_VIQMEL
      WHERE TPLNR = @LT_VIQMEL-TPLNR
      AND SPRAS = @SY-LANGU.

    SORT LT_IFLO BY TPLNR ASCENDING.

    SELECT EQUNR,TIDNR FROM EQUZ

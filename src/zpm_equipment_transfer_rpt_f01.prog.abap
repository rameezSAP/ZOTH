  LOOP AT LT_VIQMEL INTO DATA(LS_VIQMEL).
    "break ac_Adnan.
    CALL FUNCTION 'BAPI_ALM_NOTIF_GET_DETAIL'
      EXPORTING
        NUMBER             = LS_VIQMEL-QMNUM
        CLEAR_BUFFER       = 'X'
      IMPORTING
        NOTIFHEADER_EXPORT = NOTIFHEADER_EXPORT
        NOTIFHDTEXT        = NOTIFHDTEXT

          TABLES
            EXTENSIONOUT              = EXTENSIONOUT_ZONE.
        GS_MAIN-MOV_LOC = DATA_INSTALLATION-FUNCLOCSTRUCIDENTIFYINGOBJDES2.
      ENDIF.
      "GS_MAIN-MOV_LOC = VALUE #( LT_T001W[ WERKS = LS_IFLO-IWERK ]-NAME1 OPTIONAL ).
      IF NOTIFHEADER_EXPORT-MAINTPLANT <> LS_IFLO-SWERK.
        GS_MAIN-CONCESSION = 'INTRA CONCESSION'.
      ELSE.
        GS_MAIN-CONCESSION = 'INTER CONCESSION'.

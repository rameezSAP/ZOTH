FORM GET_DATA.


*For All Status text
  SELECT * FROM TJ02T
    INTO TABLE @DATA(LT_TJ02T)
    WHERE SPRAS = @SY-LANGU.

  SORT LT_TJ02T BY ISTAT ASCENDING.

  SELECT * FROM USER_ADDR
    INTO TABLE @DATA(LT_USER_ADDR).

  SORT LT_USER_ADDR BY BNAME ASCENDING.


*For Movement Type
  SELECT * FROM T353I_T
    INTO TABLE @DATA(LT_T353I_T)
    WHERE SPRAS = @SY-LANGU.

  SORT LT_T353I_T BY ILART ASCENDING.

*For Movement Type
  SELECT * FROM T001W
    INTO TABLE @DATA(LT_T001W).

  SORT LT_T001W BY WERKS ASCENDING.



*For All Document
  SELECT * FROM VIQMEL
    INTO TABLE @DATA(LT_VIQMEL)
    WHERE QMNUM IN @S_QMNUM
    AND QMART = 'M8'..

  SORT LT_VIQMEL BY QMNUM ASCENDING.



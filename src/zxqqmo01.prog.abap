MODULE STATUS_0103 OUTPUT.
  DATA:GV_FTEXT TYPE STRING.
  SELECT SINGLE PLTXT FROM IFLOTX
    INTO @GV_FTEXT
    WHERE TPLNR = @QMEL-ZQMTXT
    AND SPRAS = @SY-LANGU.
ENDMODULE.

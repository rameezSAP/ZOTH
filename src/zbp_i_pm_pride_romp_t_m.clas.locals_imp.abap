*    ENDLOOP.
*  ENDMETHOD.

  METHOD GET_INSTANCE_AUTHORIZATIONS.

  ENDMETHOD.

  METHOD ACTIVEMP.
    MODIFY ENTITIES OF ZI_PM_PRIDE_ROUTE__TEMP_M IN LOCAL MODE
  ENTITY ZI_PM_PRIDE_ROUTE_MP_TEMP_M UPDATE FIELDS ( ISACTIVE )
  WITH VALUE #( FOR LV_KEY IN KEYS ( %TKY = LV_KEY-%TKY
                                      ISACTIVE = 'X') ).

    READ ENTITIES OF ZI_PM_PRIDE_ROUTE__TEMP_M IN LOCAL MODE
    ENTITY ZI_PM_PRIDE_ROUTE_MP_TEMP_M
    ALL FIELDS WITH CORRESPONDING #( KEYS )
    RESULT DATA(LT_RT_DET).

    RESULT = VALUE #( FOR LS_RT_DET IN LT_RT_DET ( %TKY = LS_RT_DET-%TKY
    %PARAM = LS_RT_DET ) ).
  ENDMETHOD.


  METHOD GET_INSTANCE_FEATURES.
    READ ENTITIES OF ZI_PM_PRIDE_ROUTE__TEMP_M IN LOCAL MODE
   ENTITY ZI_PM_PRIDE_ROUTE_MP_TEMP_M
   FIELDS ( MEASUREPOINT ISACTIVE ) WITH CORRESPONDING #( KEYS )
   RESULT DATA(LT_RESULT).

    RESULT  = VALUE #( FOR LV_RT_D IN LT_RESULT (  %TKY = LV_RT_D-%TKY
                                                   %FEATURES-%ACTION-ACTIVEMP = COND #( WHEN LV_RT_D-ISACTIVE = ' '
                                                                                        THEN IF_ABAP_BEHV=>MK-OFF
                                                                                        WHEN LV_RT_D-ISACTIVE = 'R'
                                                                                        THEN IF_ABAP_BEHV=>MK-OFF
                                                                                        WHEN LV_RT_D-ISACTIVE = 'X'
                                                                                        THEN IF_ABAP_BEHV=>MK-ON   )
                                                   %FEATURES-%ACTION-INACTIVEMP = COND #( WHEN LV_RT_D-ISACTIVE = 'X'
                                                                                        THEN IF_ABAP_BEHV=>MK-OFF
                                                                                        WHEN LV_RT_D-ISACTIVE = 'R'
                                                                                        THEN IF_ABAP_BEHV=>MK-OFF
                                                                                        WHEN LV_RT_D-ISACTIVE = ' '
                                                                                        THEN IF_ABAP_BEHV=>MK-ON   )                                                                                           ) ).

  ENDMETHOD.

  METHOD INACTIVEMP.
    MODIFY ENTITIES OF ZI_PM_PRIDE_ROUTE__TEMP_M IN LOCAL MODE
ENTITY ZI_PM_PRIDE_ROUTE_MP_TEMP_M UPDATE FIELDS ( ISACTIVE )
WITH VALUE #( FOR LV_KEY IN KEYS ( %TKY = LV_KEY-%TKY
                                    ISACTIVE = ' ') ).

    READ ENTITIES OF ZI_PM_PRIDE_ROUTE__TEMP_M IN LOCAL MODE
    ENTITY ZI_PM_PRIDE_ROUTE_MP_TEMP_M
    ALL FIELDS WITH CORRESPONDING #( KEYS )
    RESULT DATA(LT_RT_DET).

    RESULT = VALUE #( FOR LS_RT_DET IN LT_RT_DET ( %TKY = LS_RT_DET-%TKY
    %PARAM = LS_RT_DET ) ).
  ENDMETHOD.

  METHOD REQUIREDMP.
    MODIFY ENTITIES OF ZI_PM_PRIDE_ROUTE__TEMP_M IN LOCAL MODE
ENTITY ZI_PM_PRIDE_ROUTE_MP_TEMP_M UPDATE FIELDS ( ISACTIVE )
WITH VALUE #( FOR LV_KEY IN KEYS ( %TKY = LV_KEY-%TKY
                                    ISACTIVE = 'R') ).

    READ ENTITIES OF ZI_PM_PRIDE_ROUTE__TEMP_M IN LOCAL MODE
    ENTITY ZI_PM_PRIDE_ROUTE_MP_TEMP_M
    ALL FIELDS WITH CORRESPONDING #( KEYS )
    RESULT DATA(LT_RT_DET).

    RESULT = VALUE #( FOR LS_RT_DET IN LT_RT_DET ( %TKY = LS_RT_DET-%TKY
    %PARAM = LS_RT_DET ) ).
  ENDMETHOD.

